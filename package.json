{
  "name": "sweep",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "version": "0.0.1",
  "license": "MIT",
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun run scripts/build.ts",
    "build:watch": "watchexec -w src -w node_modules/wrap-core/src bun run scripts/build.ts",
    "test": "bun test",
    "lint": "bunx biome check . --write --error-on-warnings && bunx tsc --noEmit",
    "check": "bun run lint && bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.15"
  },
  "peerDependencies": {
    "@inkjs/ui": "^2",
    "ink": "^7",
    "react": "^19",
    "typescript": "5"
  },
  "dependencies": {
    "wrap-core": "0.0.1"
  }
}
